# Rails
RAILS_ENV=development
SECRET_KEY_BASE=replace_me
DATABASE_URL=postgres://localhost:5432/promptly_development

# Redis (A/B router only)
REDIS_URL=redis://localhost:6379/0

# Anthropic (for async scoring)
ANTHROPIC_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# GitHub (for PR bot)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# OpenTelemetry (optional; leave blank to disable export)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=promptly

# Dev-only seed credentials
SEED_OWNER_EMAIL=owner@promptly.dev
SEED_OWNER_PASSWORD=promptly-dev
