<div class="auth-page">
  <div class="auth-container">
    <div class="auth-header" data-controller="reveal">
      <%= link_to root_path, class: "auth-logo" do %>
        <span class="logo-mark" aria-hidden="true">P</span>
        <span>Promptly</span>
      <% end %>
      <h1>Create your account</h1>
      <p>Free to start. No credit card required.</p>
    </div>

    <div data-controller="reveal" data-reveal-delay-value="100">
      <div class="auth-card"
           data-controller="tilt"
           data-tilt-depth-value="2"
           data-action="mousemove->tilt#mousemove mouseleave->tilt#mouseleave">
        <% if resource.errors.any? %>
          <div class="auth-errors" role="alert">
            <ul>
              <% resource.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <div class="auth-field">
            <%= f.label :name, "Full name", class: "auth-label" %>
            <%= f.text_field :name,
                  autofocus: true,
                  autocomplete: "name",
                  placeholder: "Ada Lovelace",
                  class: "auth-input" %>
          </div>

          <div class="auth-field">
            <%= f.label :email, "Work email", class: "auth-label" %>
            <%= f.email_field :email,
                  autocomplete: "email",
                  placeholder: "you@company.com",
                  class: "auth-input" %>
          </div>

          <div class="auth-field">
            <%= f.label :password, class: "auth-label" %>
            <% if @minimum_password_length %>
              <%= f.password_field :password,
                    autocomplete: "new-password",
                    placeholder: "Min. #{@minimum_password_length} characters",
                    class: "auth-input" %>
            <% else %>
              <%= f.password_field :password,
                    autocomplete: "new-password",
                    placeholder: "Min. 8 characters",
                    class: "auth-input" %>
            <% end %>
          </div>

          <%= f.submit "Create account", class: "auth-btn" %>
        <% end %>

        <div class="auth-divider"><span>or</span></div>

        <button type="button" class="auth-google-btn" disabled aria-label="Sign up with Google (coming soon)">
          <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Sign up with Google
        </button>

        <p class="auth-terms">
          By signing up you agree to our Terms of Service and Privacy Policy.
        </p>
      </div>
    </div>

    <p class="auth-switch" data-controller="reveal" data-reveal-delay-value="200">
      Already have an account?
      <%= link_to "Log in", new_session_path(resource_name) %>
    </p>
  </div>
</div>
