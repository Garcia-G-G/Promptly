<!DOCTYPE html>
<html>
<head>
  <title>Promptly - Version control for your LLM prompts</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Ship prompts like code. A/B test variants, track scores, and roll back.">

  <!-- Open Graph -->
  <meta property="og:title" content="Promptly - Version control for your LLM prompts">
  <meta property="og:description" content="Ship prompts like code. A/B test, score, and deploy with confidence.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://promptly.dev">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Promptly - Prompt version control">
  <meta name="twitter:description" content="Ship prompts like code. A/B test, score, and deploy with confidence.">

  <!-- Font preloading -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "landing", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <!-- Structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Promptly",
    "applicationCategory": "DeveloperApplication",
    "description": "Prompt version control and A/B testing platform for LLM applications",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
  </script>
</head>
<body>
  <canvas data-controller="canvas-grid" style="position:fixed;inset:0;z-index:0;pointer-events:none;"></canvas>
  <%= yield %>
</body>
</html>
