<% content_for :page_title, "Logs" %>

<div class="page-header">
  <h1>Logs</h1>
  <p>Browse SDK call logs, scores, and experiment results.</p>
</div>

<div class="stat-grid" style="margin-bottom: 20px;">
  <div class="stat-card">
    <div class="stat-card__label">Total logs</div>
    <div class="stat-card__value"><%= number_with_delimiter(@total_count) %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Avg latency</div>
    <div class="stat-card__value"><%= @avg_latency ? "#{@avg_latency}ms" : "—" %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">Avg score</div>
    <div class="stat-card__value"><%= @avg_score || "—" %></div>
  </div>
  <div class="stat-card">
    <div class="stat-card__label">p95 latency</div>
    <div class="stat-card__value"><%= @p95_latency ? "#{@p95_latency}ms" : "—" %></div>
  </div>
</div>

<div class="filter-bar">
  <%= form_with url: workspace_web_logs_path(@workspace.slug),
        method: :get, local: true, class: "filter-bar__form" do %>
    <div class="filter-bar__group">
      <label class="filter-bar__label">Prompt</label>
      <select name="prompt_id" class="filter-bar__input">
        <option value="">All prompts</option>
        <% @prompts.each do |prompt| %>
          <option value="<%= prompt.id %>" <%= "selected" if params[:prompt_id].to_s == prompt.id.to_s %>>
            <%= prompt.slug %>
          </option>
        <% end %>
      </select>
    </div>

    <div class="filter-bar__group">
      <label class="filter-bar__label">From</label>
      <input type="date" name="from" value="<%= params[:from] %>" class="filter-bar__input">
    </div>

    <div class="filter-bar__group">
      <label class="filter-bar__label">To</label>
      <input type="date" name="to" value="<%= params[:to] %>" class="filter-bar__input">
    </div>

    <div class="filter-bar__group">
      <label class="filter-bar__label">Min score</label>
      <input type="number" name="min_score" step="0.01" min="0" max="1"
             placeholder="0.0" value="<%= params[:min_score] %>" class="filter-bar__input">
    </div>

    <div class="filter-bar__group">
      <label class="filter-bar__label">Max score</label>
      <input type="number" name="max_score" step="0.01" min="0" max="1"
             placeholder="1.0" value="<%= params[:max_score] %>" class="filter-bar__input">
    </div>

    <div class="filter-bar__group">
      <label class="filter-bar__label filter-bar__checkbox">
        <input type="checkbox" name="has_experiment" value="1" <%= "checked" if params[:has_experiment] == "1" %>>
        <span>In experiment</span>
      </label>
    </div>

    <div class="filter-bar__group filter-bar__group--actions">
      <button type="submit" class="btn btn--secondary btn--sm">Filter</button>
      <% if %i[prompt_id from to min_score max_score has_experiment].any? { |k| params[k].present? } %>
        <%= link_to "Clear", workspace_web_logs_path(@workspace.slug), class: "btn btn--secondary btn--sm" %>
      <% end %>
    </div>
  <% end %>
</div>

<% if @logs.any? %>
  <div class="card" style="padding: 0; overflow: hidden; margin-top: 16px;">
    <table class="data-table">
      <thead>
        <tr>
          <th>Timestamp</th>
          <th>Prompt</th>
          <th>Version</th>
          <th>Latency</th>
          <th>Score</th>
          <th>Variant</th>
          <th>Model</th>
        </tr>
      </thead>
      <tbody>
        <% @logs.each do |log| %>
          <tr onclick="Turbo.visit('<%= workspace_web_log_path(@workspace.slug, log) %>')" style="cursor: pointer;">
            <td style="font-family: var(--font-mono); font-size: 12px; color: var(--t2); white-space: nowrap;">
              <%= log.created_at.strftime("%b %d %H:%M:%S") %>
            </td>
            <td><code style="font-family: var(--font-mono); font-size: 12px;"><%= log.prompt&.slug %></code></td>
            <td style="font-family: var(--font-mono); font-size: 12px;">v<%= log.prompt_version&.version_number %></td>
            <td style="font-family: var(--font-mono); font-size: 12px;">
              <%= log.latency_ms ? "#{log.latency_ms}ms" : "—" %>
            </td>
            <td>
              <% if log.score %>
                <% score_class = log.score >= 0.7 ? "score-cell--high" : log.score >= 0.4 ? "score-cell--mid" : "score-cell--low" %>
                <span class="<%= score_class %>" style="font-family: var(--font-mono); font-weight: 600; font-size: 12px;"><%= log.score.round(3) %></span>
              <% else %>
                <span style="color: var(--t3); font-size: 12px;">—</span>
              <% end %>
            </td>
            <td>
              <% if log.variant %>
                <span class="badge badge--<%= log.variant == 'a' ? 'green' : 'amber' %>"><%= log.variant.upcase %></span>
              <% else %>
                <span style="color: var(--t3);">—</span>
              <% end %>
            </td>
            <td style="font-family: var(--font-mono); font-size: 11px; color: var(--t3);">
              <%= log.model_version.to_s.truncate(20) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @total_pages > 1 %>
    <div style="display: flex; justify-content: center; gap: 4px; margin-top: 20px; align-items: center;">
      <% pagination_params = params.permit(:prompt_id, :from, :to, :min_score, :max_score, :has_experiment).to_h %>
      <% if @page > 1 %>
        <%= link_to "Previous", workspace_web_logs_path(@workspace.slug, pagination_params.merge(page: @page - 1)), class: "btn btn--secondary btn--sm" %>
      <% end %>
      <span style="padding: 0 12px; font-size: 13px; color: var(--t3);">Page <%= @page %> of <%= @total_pages %></span>
      <% if @page < @total_pages %>
        <%= link_to "Next", workspace_web_logs_path(@workspace.slug, pagination_params.merge(page: @page + 1)), class: "btn btn--secondary btn--sm" %>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="card" style="text-align: center; padding: 60px 20px; margin-top: 16px;">
    <p style="font-size: 15px; color: var(--t2); margin-bottom: 8px;">No logs found.</p>
    <p style="font-size: 13px; color: var(--t3);">Logs appear here when your SDK calls <code style="font-family: var(--font-mono);">Promptly.log</code> or <code style="font-family: var(--font-mono);">Promptly.with</code>.</p>
  </div>
<% end %>
