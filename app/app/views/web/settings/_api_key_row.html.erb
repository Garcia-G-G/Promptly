<%# locals: (api_key:) %>
<tr id="<%= dom_id(api_key) %>" class="<%= 'revoked' if api_key.revoked? %>">
  <td>
    <span class="<%= 'revoked__text' if api_key.revoked? %>"><%= api_key.name %></span>
  </td>
  <td>
    <code class="<%= 'revoked__text' if api_key.revoked? %>"
          style="font-family: var(--font-mono); font-size: 13px;">
      <%= api_key.key_prefix %>…
    </code>
  </td>
  <td style="color: var(--t3); font-size: 12px;"><%= api_key.created_at.strftime("%b %d, %Y") %></td>
  <td style="color: var(--t3); font-size: 12px;">
    <%= api_key.last_used_at ? "#{time_ago_in_words(api_key.last_used_at)} ago" : "Never" %>
  </td>
  <td>
    <% if api_key.revoked? %>
      <span class="badge badge--red" style="opacity: 0.7;">Revoked</span>
    <% else %>
      <span class="badge badge--green">Active</span>
    <% end %>
  </td>
  <td>
    <% unless api_key.revoked? %>
      <%= button_to "Revoke",
            revoke_api_key_workspace_web_settings_path(@workspace.slug, api_key.id),
            method: :delete,
            class: "btn btn--danger btn--sm",
            form: { data: { turbo_confirm: "Revoke API key '#{api_key.name}'? This cannot be undone." } } %>
    <% end %>
  </td>
</tr>
