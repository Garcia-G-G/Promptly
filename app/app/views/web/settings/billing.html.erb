<% content_for :page_title, "Billing" %>

<%= render "web/settings/settings_tabs", current_tab: :billing %>

<div style="margin-top: 24px;">
  <% if @stripe_configured %>
    <div class="plan-card" style="margin-bottom: 24px;">
      <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; flex-wrap: wrap;">
        <div>
          <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 4px;"><%= @plan_name %> plan</h2>
          <p style="font-size: 13px; color: var(--t2);">
            Billing period: <%= @billing_period_start.strftime("%b %d") %> — <%= @billing_period_end.strftime("%b %d, %Y") %>
          </p>
        </div>
        <% if @portal_url %>
          <%= link_to "Manage subscription", @portal_url,
                class: "btn btn--primary", target: "_blank", rel: "noopener" %>
        <% end %>
      </div>
    </div>

    <div class="card" style="margin-bottom: 24px;">
      <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 20px;">Usage this period</h3>
      <% @usage_meters.each do |meter| %>
        <%
          infinite = meter[:limit] == Float::INFINITY
          pct = infinite ? 0 : [ (meter[:current].to_f / meter[:limit] * 100), 100 ].min
          fill_class = if pct > 95 then "usage-meter__fill--danger"
                       elsif pct > 80 then "usage-meter__fill--warning"
                       end
        %>
        <div class="usage-meter" style="margin-bottom: 20px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
            <span style="font-size: 13px; font-weight: 500;"><%= meter[:label] %></span>
            <span style="font-size: 13px; color: var(--t2); font-family: var(--font-mono);">
              <%= number_with_delimiter(meter[:current]) %> / <%= infinite ? "Unlimited" : number_with_delimiter(meter[:limit]) %>
            </span>
          </div>
          <div class="usage-meter__track">
            <div class="usage-meter__fill <%= fill_class %>" style="width: <%= pct %>%;"></div>
          </div>
          <% if !infinite && pct > 80 %>
            <p style="font-size: 11px; color: <%= pct > 95 ? 'var(--red)' : 'var(--amber)' %>; margin-top: 4px;">
              <%= (100 - pct).round(1) %>% remaining
            </p>
          <% end %>
        </div>
      <% end %>
    </div>

    <% if @workspace.plan.to_s.in?([ "", "free" ]) %>
      <div class="card" style="margin-bottom: 24px;">
        <h3 style="font-size: 16px; font-weight: 600; margin-bottom: 20px;">Upgrade your plan</h3>
        <div class="plan-comparison">
          <table class="data-table">
            <thead>
              <tr>
                <th>Feature</th>
                <th>Free</th>
                <th>Starter — $29/mo</th>
                <th>Pro — $79/mo</th>
              </tr>
            </thead>
            <tbody>
              <%
                rows = [
                  [ "Projects",            "1",     "5",            "Unlimited" ],
                  [ "SDK calls / month",   "1,000", "50,000",       "500,000" ],
                  [ "Active experiments",  "—",     "3",            "Unlimited" ],
                  [ "Eval runs / month",   "10",    "100",          "Unlimited" ],
                  [ "Team members",        "1",     "3",            "Unlimited" ],
                  [ "GitHub integration",  "—",     "—",            :check ],
                  [ "Security scans",      "—",     "—",            :check ],
                  [ "Overage rate",        "—",     "$0.0002/call", "$0.0002/call" ]
                ]
              %>
              <% rows.each do |feature, free, starter, pro| %>
                <tr>
                  <td><%= feature %></td>
                  <td style="color: var(--t3);"><%= free %></td>
                  <td><%= starter %></td>
                  <td>
                    <% if pro == :check %>
                      <span style="color: var(--green); font-weight: 600;">✓</span>
                    <% else %>
                      <%= pro %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

    <% if @invoices.any? %>
      <div class="card" style="padding: 0; overflow: hidden;">
        <div style="padding: 16px 20px; border-bottom: 1px solid var(--card-border);">
          <h3 style="font-size: 16px; font-weight: 600;">Invoice history</h3>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Invoice</th>
            </tr>
          </thead>
          <tbody>
            <% @invoices.each do |invoice| %>
              <%
                status_color = case invoice.status
                               when "paid" then "green"
                               when "open" then "amber"
                               else "red"
                               end
              %>
              <tr>
                <td><%= Time.at(invoice.created).strftime("%b %d, %Y") %></td>
                <td style="font-family: var(--font-mono); font-weight: 500;">
                  $<%= "%.2f" % (invoice.amount_due / 100.0) %>
                </td>
                <td><span class="badge badge--<%= status_color %>"><%= invoice.status.titleize %></span></td>
                <td>
                  <% if invoice.invoice_pdf.present? %>
                    <%= link_to "Download PDF", invoice.invoice_pdf,
                          target: "_blank", rel: "noopener",
                          style: "font-size: 13px; color: var(--accent); text-decoration: none;" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  <% else %>
    <div class="card" style="text-align: center; padding: 60px 20px;">
      <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">Billing not configured</h2>
      <p style="font-size: 14px; color: var(--t2); max-width: 440px; margin: 0 auto 16px;">
        Stripe integration is not configured yet. Set
        <code style="font-family: var(--font-mono); font-size: 12px;">STRIPE_SECRET_KEY</code>
        in the environment and connect a Stripe customer to this workspace to enable billing features.
      </p>
      <h3 style="font-size: 14px; font-weight: 600; margin-top: 32px; margin-bottom: 16px; color: var(--t2);">Current usage</h3>
      <div style="max-width: 480px; margin: 0 auto; text-align: left;">
        <% @usage_meters.each do |meter| %>
          <%
            infinite = meter[:limit] == Float::INFINITY
            pct = infinite ? 0 : [ (meter[:current].to_f / meter[:limit] * 100), 100 ].min
          %>
          <div class="usage-meter" style="margin-bottom: 12px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 4px; font-size: 13px;">
              <span><%= meter[:label] %></span>
              <span style="color: var(--t2); font-family: var(--font-mono);">
                <%= number_with_delimiter(meter[:current]) %> / <%= infinite ? "Unlimited" : number_with_delimiter(meter[:limit]) %>
              </span>
            </div>
            <div class="usage-meter__track">
              <div class="usage-meter__fill" style="width: <%= pct %>%;"></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
