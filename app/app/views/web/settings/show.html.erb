<% content_for :page_title, "Settings" %>

<%= render "web/settings/settings_tabs", current_tab: :general %>

<div style="max-width: 640px; margin-top: 24px;">
  <div class="card">
    <h2 style="font-size: 16px; font-weight: 600; margin-bottom: 20px;">Workspace settings</h2>

    <%= form_with model: @workspace,
          url: workspace_web_settings_path(@workspace.slug),
          method: :patch, local: true, class: "form" do |f| %>
      <div class="form-group">
        <%= f.label :name, "Workspace name", class: "form-label" %>
        <%= f.text_field :name, class: "form-input", placeholder: "My Workspace" %>
      </div>

      <div class="form-group">
        <label class="form-label">Slug</label>
        <div style="font-family: var(--font-mono); font-size: 14px; padding: 9px 12px; background: var(--bg); border: 1px solid var(--card-border); border-radius: var(--radius-sm); color: var(--t3);">
          <%= @workspace.slug %>
        </div>
        <p class="form-hint">Slug cannot be changed after creation.</p>
      </div>

      <div class="form-group">
        <label class="form-label">Owner</label>
        <div style="font-size: 14px; padding: 9px 0; color: var(--t2);">
          <%= @workspace.owner.name %>
          <span style="color: var(--t3);">(<%= @workspace.owner.email %>)</span>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Plan</label>
        <div style="padding: 9px 0;">
          <%
            plan = (@workspace.plan.presence || "free").downcase
            plan_color = case plan
                         when "pro", "enterprise" then "green"
                         when "starter" then "amber"
                         else "blue"
                         end
          %>
          <span class="badge badge--<%= plan_color %>"><%= plan.titleize %></span>
        </div>
      </div>

      <div style="margin-top: 24px;">
        <%= f.submit "Save changes", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>

  <div class="danger-zone" style="margin-top: 32px;">
    <h3 style="font-size: 14px; font-weight: 600; color: var(--red); margin-bottom: 8px;">Danger zone</h3>
    <p style="font-size: 13px; color: var(--t2); margin-bottom: 16px;">
      Deleting this workspace will permanently remove all projects, prompts, experiments, logs, and API keys. This action cannot be undone.
    </p>
    <button type="button" class="btn btn--danger" disabled
            title="Workspace deletion is not yet available — contact support to delete a workspace.">
      Delete this workspace
    </button>
  </div>
</div>
