<% content_for :page_title, @dataset.name %>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start;">
  <div>
    <%= link_to "&larr; Datasets".html_safe, workspace_web_datasets_path(@workspace.slug),
          style: "font-size: 13px; color: var(--t3); text-decoration: none;" %>
    <h1 style="margin-top: 8px;"><%= @dataset.name %></h1>
    <div style="display: flex; gap: 12px; align-items: center; margin-top: 4px; flex-wrap: wrap;">
      <span style="font-size: 13px; color: var(--t3); font-family: var(--font-mono);"><%= @dataset.project.name %></span>
      <span class="badge badge--blue"><%= @dataset.dataset_rows_count %> rows</span>
    </div>
    <% if @dataset.description.present? %>
      <p style="font-size: 14px; color: var(--t2); margin-top: 8px;"><%= @dataset.description %></p>
    <% end %>
  </div>
  <div style="display: flex; gap: 6px;">
    <button type="button" class="btn btn--secondary btn--sm"
            onclick="document.getElementById('import-section').classList.toggle('hidden')">
      Import rows
    </button>
    <%= button_to "Delete",
          workspace_web_dataset_path(@workspace.slug, @dataset),
          method: :delete,
          class: "btn btn--danger btn--sm",
          data: { turbo_confirm: "Delete dataset '#{@dataset.name}' and all its rows? This cannot be undone." } %>
  </div>
</div>

<div class="card hidden" id="import-section" style="margin-bottom: 24px;">
  <h3 style="font-size: 14px; font-weight: 600; margin-bottom: 16px;">Import rows</h3>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
    <div>
      <h4 style="font-size: 13px; font-weight: 500; color: var(--t2); margin-bottom: 8px;">Upload CSV</h4>
      <%= form_with url: import_workspace_web_dataset_path(@workspace.slug, @dataset),
            method: :post, multipart: true, local: true,
            style: "display: flex; flex-direction: column; gap: 8px;" do %>
        <input type="file" name="csv_file" accept=".csv" class="form-input" style="padding: 8px;">
        <p class="form-hint">CSV with headers. Columns become <code>input_vars</code>. Optional: <code>expected_output</code>, <code>tags</code> (semicolon-separated).</p>
        <button type="submit" class="btn btn--primary btn--sm" style="align-self: flex-start;">Upload CSV</button>
      <% end %>
    </div>
    <div>
      <h4 style="font-size: 13px; font-weight: 500; color: var(--t2); margin-bottom: 8px;">Paste JSON</h4>
      <%= form_with url: import_workspace_web_dataset_path(@workspace.slug, @dataset),
            method: :post, local: true,
            style: "display: flex; flex-direction: column; gap: 8px;" do %>
        <textarea name="json_rows" rows="6" class="form-input json-viewer"
                  placeholder='[
  {"input_vars": {"language": "Spanish", "topic": "AI"}, "expected_output": "...", "tags": ["test"]}
]'></textarea>
        <button type="submit" class="btn btn--primary btn--sm" style="align-self: flex-start;">Import JSON</button>
      <% end %>
    </div>
  </div>
</div>

<% if @rows.any? %>
  <div class="card" style="padding: 0; overflow: hidden;">
    <table class="data-table">
      <thead>
        <tr>
          <th style="width: 60px;">#</th>
          <th>Input variables</th>
          <th>Expected output</th>
          <th>Tags</th>
        </tr>
      </thead>
      <tbody>
        <% @rows.each_with_index do |row, idx| %>
          <tr>
            <td style="font-family: var(--font-mono); font-size: 12px; color: var(--t3);">
              <%= (@current_page - 1) * 100 + idx + 1 %>
            </td>
            <td>
              <div class="json-viewer" style="max-width: 400px;">
                <% row.input_vars.each do |key, value| %>
                  <span class="json-viewer__key"><%= key %></span>=<span class="json-viewer__value"><%= truncate(value.to_s, length: 60) %></span>
                <% end %>
              </div>
            </td>
            <td style="color: var(--t2); font-size: 13px; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <% if row.expected_output.present? %>
                <%= truncate(row.expected_output, length: 80) %>
              <% else %>
                <span style="color: var(--t3); font-style: italic;">none</span>
              <% end %>
            </td>
            <td>
              <% Array(row.tags).each do |tag| %>
                <span class="tag-badge"><%= tag %></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @has_more %>
    <div style="text-align: center; margin-top: 16px;">
      <%= link_to "Load more rows",
            workspace_web_dataset_path(@workspace.slug, @dataset, page: @current_page + 1),
            class: "btn btn--secondary btn--sm" %>
    </div>
  <% end %>
<% else %>
  <div class="card" style="text-align: center; padding: 40px 20px;">
    <p style="font-size: 14px; color: var(--t2); margin-bottom: 12px;">No rows in this dataset yet.</p>
    <p style="font-size: 12px; color: var(--t3);">Use the Import rows button above to add some.</p>
  </div>
<% end %>
