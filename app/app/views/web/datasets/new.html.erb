<% content_for :page_title, "New dataset" %>

<div class="page-header">
  <%= link_to "&larr; Datasets".html_safe, workspace_web_datasets_path(@workspace.slug),
        style: "font-size: 13px; color: var(--t3); text-decoration: none;" %>
  <h1 style="margin-top: 8px;">New dataset</h1>
</div>

<div class="card" style="max-width: 680px;">
  <%= form_with url: workspace_web_datasets_path(@workspace.slug),
        method: :post, multipart: true, local: true, class: "form" do %>
    <div class="form-group">
      <label class="form-label" for="dataset_project_id">Project</label>
      <select name="dataset[project_id]" id="dataset_project_id" class="form-input" required>
        <option value="">Select a project…</option>
        <% @projects.each do |project| %>
          <option value="<%= project.id %>"><%= project.name %></option>
        <% end %>
      </select>
    </div>

    <div class="form-group">
      <label class="form-label" for="dataset_name">Name</label>
      <input type="text" name="dataset[name]" id="dataset_name" value="<%= @dataset.name %>"
             placeholder="summarizer-test-cases" class="form-input" required>
      <p class="form-hint">Unique name within the project.</p>
    </div>

    <div class="form-group">
      <label class="form-label" for="dataset_description">Description</label>
      <textarea name="dataset[description]" id="dataset_description" rows="2"
                placeholder="Test cases for evaluating the document summarizer prompt"
                class="form-input"><%= @dataset.description %></textarea>
    </div>

    <hr style="border: none; border-top: 1px solid var(--card-border); margin: 24px 0;">

    <h3 style="font-size: 14px; font-weight: 600; margin-bottom: 12px;">Initial rows (optional)</h3>
    <p class="form-hint" style="margin-bottom: 16px;">You can also import rows after creating the dataset.</p>

    <div class="form-group">
      <label class="form-label">Upload CSV</label>
      <input type="file" name="dataset[csv_file]" accept=".csv" class="form-input" style="padding: 8px;">
      <p class="form-hint">CSV with headers. Each column becomes an input variable. Optional: <code>expected_output</code>, <code>tags</code> (semicolon-separated).</p>
    </div>

    <div class="form-group">
      <label class="form-label">Or paste JSON</label>
      <textarea name="dataset[json_rows]" rows="6" class="form-input json-viewer"
                placeholder='[
  {"input_vars": {"language": "Spanish", "topic": "AI"}, "expected_output": "A summary about AI in Spanish"}
]'></textarea>
      <p class="form-hint">JSON array of objects. Each must have <code>input_vars</code>. Optional: <code>expected_output</code>, <code>tags</code>.</p>
    </div>

    <div style="display: flex; gap: 8px; margin-top: 24px;">
      <button type="submit" class="btn btn--primary">Create dataset</button>
      <%= link_to "Cancel", workspace_web_datasets_path(@workspace.slug), class: "btn btn--secondary" %>
    </div>
  <% end %>
</div>
