<% content_for :page_title, "Eval Runs" %>

<div class="page-header">
  <h1>Eval Runs</h1>
  <p><%= pluralize(@eval_runs.size, "run") %></p>
</div>

<% if @eval_runs.any? %>
  <div class="card" style="padding: 0; overflow: hidden;">
    <table class="data-table">
      <thead>
        <tr><th>Prompt</th><th>Dataset</th><th>Version</th><th>Status</th><th>Avg score</th><th>Started</th></tr>
      </thead>
      <tbody>
        <% @eval_runs.each do |run| %>
          <tr>
            <td><code style="font-family: var(--font-mono);"><%= run.prompt_version&.prompt&.slug || "—" %></code></td>
            <td><%= run.dataset&.name %></td>
            <td style="font-family: var(--font-mono);">v<%= run.prompt_version&.version_number %></td>
            <td><span class="badge badge--<%= run.status == 'completed' ? 'green' : run.status == 'failed' ? 'red' : 'amber' %>"><%= run.status %></span></td>
            <td style="font-family: var(--font-mono); font-weight: 600;"><%= run.aggregate_score&.round(2) || "—" %></td>
            <td style="color: var(--t3); font-size: 12px;"><%= time_ago_in_words(run.created_at) %> ago</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card" style="text-align: center; padding: 48px 20px;">
    <p style="color: var(--t2); font-size: 14px;">No eval runs yet. Trigger one from the API after uploading a dataset.</p>
  </div>
<% end %>
