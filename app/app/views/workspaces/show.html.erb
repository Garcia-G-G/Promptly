<h1><%= @workspace.name %></h1>

<h2>Projects</h2>

<% if @projects.any? %>
  <ul>
    <% @projects.each do |project| %>
      <li>
        <%= link_to project.name, workspace_project_path(@workspace.slug, project.slug) %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No projects yet.</p>
<% end %>

<%= link_to "New Project", new_workspace_project_path(@workspace.slug) %>
