<%# Hero — product-first, code IS the hero %>
<section class="hero">
  <p class="hero__eyebrow reveal">
    <span class="hero__dot"></span>
    Now in public beta
  </p>

  <h1 class="hero__h1 reveal reveal-d1">
    Prompts are code.<br>
    <em>Treat them that way.</em>
  </h1>

  <p class="hero__sub reveal reveal-d2">
    Version, A/B test, score, and deploy your LLM prompts<br class="hide-mobile">
    from one place your whole team can trust.
  </p>

  <div class="hero__buttons reveal reveal-d3">
    <%= link_to "Start building — free", new_user_registration_path, class: "btn-accent" %>
    <a href="#features" class="btn-ghost">See how it works &darr;</a>
  </div>

  <%# The code window — this IS the product pitch %>
  <div class="terminal reveal reveal-d4" data-controller="tilt" data-tilt-depth-value="2" data-action="mousemove->tilt#mousemove mouseleave->tilt#mouseleave">
    <div class="terminal__chrome">
      <div class="terminal__dots"><i></i><i></i><i></i></div>
      <span class="terminal__tab">app.rb</span>
    </div>
    <pre class="terminal__code"><span class="ln"> 1</span>  <span class="kw">require</span> <span class="s">"promptly"</span>
<span class="ln"> 2</span>
<span class="ln"> 3</span>  <span class="c"># Resolve the active prompt — environment-aware,</span>
<span class="ln"> 4</span>  <span class="c"># A/B routed, scored automatically.</span>
<span class="ln"> 5</span>  prompt = <span class="v">Promptly</span>.get(<span class="s">"onboarding-email"</span>)
<span class="ln"> 6</span>
<span class="ln"> 7</span>  result = anthropic.messages.create(
<span class="ln"> 8</span>    model: prompt.<span class="v">model_hint</span>,
<span class="ln"> 9</span>    messages: [{ role: <span class="s">"user"</span>, content: prompt.to_s }]
<span class="ln">10</span>  )
<span class="ln">11</span>
<span class="ln">12</span>  <span class="v">Promptly</span>.log(prompt_slug: <span class="s">"onboarding-email"</span>, output: result)</pre>
  </div>
</section>

<%# Features — three big cards, not a long list %>
<section class="features" id="features">
  <div class="features__intro reveal">
    <span class="tag">How it works</span>
    <h2>Push. Test. Ship.</h2>
  </div>

  <div class="features__grid">
    <div class="fcard reveal reveal-d1">
      <div class="fcard__number">01</div>
      <h3>Version everything</h3>
      <p>Every prompt edit is an immutable version with a SHA-256 hash. Diff any two, roll back in one click. No more "which Slack message had the latest prompt?"</p>
    </div>

    <div class="fcard reveal reveal-d2">
      <div class="fcard__number">02</div>
      <h3>A/B test in production</h3>
      <p>Split traffic between variants with sticky sessions. Canary from 1% to 100%. Bayesian significance testing declares winners — no spreadsheets required.</p>
    </div>

    <div class="fcard reveal reveal-d3">
      <div class="fcard__number">03</div>
      <h3>Score every output</h3>
      <p>Attach LLM-as-judge scorers or regex matchers. Run eval datasets before promoting. Security scans catch injection patterns before they reach production.</p>
    </div>
  </div>

  <div class="features__detail reveal reveal-d4">
    <div class="features__detail-list">
      <div class="fdetail">
        <span class="fdetail__label">Environments</span>
        <span class="fdetail__value">dev &rarr; staging &rarr; production</span>
      </div>
      <div class="fdetail">
        <span class="fdetail__label">Resolve p95</span>
        <span class="fdetail__value">&lt; 8ms</span>
      </div>
      <div class="fdetail">
        <span class="fdetail__label">SDK</span>
        <span class="fdetail__value">Ruby (Python, JS coming)</span>
      </div>
      <div class="fdetail">
        <span class="fdetail__label">Observability</span>
        <span class="fdetail__value">OpenTelemetry GenAI native</span>
      </div>
    </div>
  </div>
</section>

<%# Pricing — dead simple %>
<section class="pricing" id="pricing">
  <div class="pricing__intro reveal">
    <span class="tag">Pricing</span>
    <h2>Start free. Scale later.</h2>
  </div>

  <div class="pricing__cards">
    <div class="pcard reveal reveal-d1">
      <div class="pcard__name">Free</div>
      <div class="pcard__price">$0</div>
      <ul class="pcard__list">
        <li>3 projects</li>
        <li>10k resolves / month</li>
        <li>2 team members</li>
        <li>Community support</li>
      </ul>
      <%= link_to "Get started", new_user_registration_path, class: "btn-ghost btn-ghost--full" %>
    </div>

    <div class="pcard pcard--pro reveal reveal-d2">
      <div class="pcard__badge">Most popular</div>
      <div class="pcard__name">Pro</div>
      <div class="pcard__price">$49<span>/mo</span></div>
      <ul class="pcard__list">
        <li>Unlimited projects</li>
        <li>Unlimited resolves</li>
        <li>Unlimited members</li>
        <li>A/B testing + scoring</li>
        <li>Security scans</li>
        <li>Priority support</li>
      </ul>
      <%= link_to "Start free trial", new_user_registration_path, class: "btn-accent btn-accent--full" %>
    </div>
  </div>
</section>

